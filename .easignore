# EAS Build ignore file
# This is a copy of .gitignore but WITHOUT .env
# so that environment variables are available during local builds

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Native
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files (keep .env for build, ignore .env.local variants)
.env*.local

# typescript
*.tsbuildinfo

# testing
coverage/

# IDE
.vscode/
.idea/
google-services.json

# docs
docs/
TODO.MD
*.apk
AppIcons.zip
migrations/
